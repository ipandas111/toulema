# Claude API (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Tavily Search API (https://tavily.com, 1000次/月免费)
TAVILY_API_KEY=tvly-...

# Database (本地开发用 docker-compose 默认值即可)
DATABASE_URL=postgresql://jobtrack:jobtrack@localhost:5432/jobtrack

# Redis (本地开发用 docker-compose 默认值即可)
REDIS_URL=redis://localhost:6379/0

# ChromaDB 持久化路径 (开发环境)
CHROMA_PERSIST_DIR=./chroma_data

# 面经质量评分阈值
QUALITY_THRESHOLD_DISCARD=4.0
QUALITY_THRESHOLD_FULL=6.0

# CORS (生产环境填前端域名)
CORS_ORIGINS=http://localhost:5173,https://your-app.vercel.app
